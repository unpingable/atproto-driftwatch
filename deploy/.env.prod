# Driftwatch — Stage 0: Sealed Lab
# Ingest from firehose, compute metrics, no emits.

# Jetstream (JSON firehose — no CBOR/CAR parsing needed)
FIREHOSE_AUTO_START=1
FIREHOSE_WS_URL=wss://jetstream2.us-east.bsky.network/subscribe
JETSTREAM_COLLECTIONS=app.bsky.feed.post,app.bsky.feed.repost
CURSOR_SAVE_INTERVAL=500

# No upstream label ingestion (sealed lab)
FIREHOSE_LABEL_INGEST=0

# Longitudinal recheck loop
ENABLE_LONGITUDINAL_RECHECK=1
RECHECK_INTERVAL=300
RECHECK_BATCH_SIZE=10
ENABLE_CLAIM_RECHECK=1
CLAIM_RECHECK_MAX_PER_RUN=10
RECHECK_QUEUE_MAX=10000

# Emit mode: detect-only (NO public labels)
LABELER_EMIT_MODE=detect-only
LABELER_EMIT_CONFIRM=false

# Database
DB_BACKEND=sqlite

# Fingerprint config (defaults)
FINGERPRINT_QUOTE_KEEP=false
FINGERPRINT_NUMBER_MODE=bucket
FINGERPRINT_ENTITY_CANON=none
